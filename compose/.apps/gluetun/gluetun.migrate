##
## GLUETUN - .env
##
.env:GLUETUN__CONTAINER_NAME .env:GLUETUN_CONTAINER_NAME
.env:GLUETUN__ENABLED .env:GLUETUN_ENABLED
.env:GLUETUN__NETWORK_MODE .env:GLUETUN_NETWORK_MODE
.env:GLUETUN__PORT_8000 .env:GLUETUN_PORT_8000
.env:GLUETUN__PORT_8388 .env:GLUETUN_PORT_8388
.env:GLUETUN__PORT_8888 .env:GLUETUN_PORT_8888
.env:GLUETUN__RESTART .env:GLUETUN_RESTART
.env:GLUETUN__TAG .env:GLUETUN_TAG

##
## GLUETUN - gluetun.env
