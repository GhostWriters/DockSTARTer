##
## ORGANIZR - .env
##
.env:ORGANIZR__CONTAINER_NAME .env:ORGANIZR_CONTAINER_NAME
.env:ORGANIZR__ENABLED .env:ORGANIZR_ENABLED
.env:ORGANIZR__NETWORK_MODE .env:ORGANIZR_NETWORK_MODE
.env:ORGANIZR__PORT_80 .env:ORGANIZR_PORT_80
.env:ORGANIZR__RESTART .env:ORGANIZR_RESTART
.env:ORGANIZR__TAG .env:ORGANIZR_TAG

##
## ORGANIZR - organizr.env
##
organizr.env:branch .env:(ORGANIZR_branch|ORGANIZR_ENVIRONMENT_branch)
organizr.env:fpm .env:(ORGANIZR_fpm|ORGANIZR_ENVIRONMENT_fpm)
