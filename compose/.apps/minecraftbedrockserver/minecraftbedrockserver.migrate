##
## MINECRAFTBEDROCKSERVER - .env
##
.env:MINECRAFTBEDROCKSERVER__CONTAINER_NAME .env:MINECRAFTBEDROCKSERVER_CONTAINER_NAME
.env:MINECRAFTBEDROCKSERVER__ENABLED .env:MINECRAFTBEDROCKSERVER_ENABLED
.env:MINECRAFTBEDROCKSERVER__NETWORK_MODE .env:MINECRAFTBEDROCKSERVER_NETWORK_MODE
.env:MINECRAFTBEDROCKSERVER__PORT_19132 .env:MINECRAFTBEDROCKSERVER_PORT_19132
.env:MINECRAFTBEDROCKSERVER__RESTART .env:MINECRAFTBEDROCKSERVER_RESTART
.env:MINECRAFTBEDROCKSERVER__TAG .env:MINECRAFTBEDROCKSERVER_TAG

##
## MINECRAFTBEDROCKSERVER - minecraftbedrockserver.env
##
minecraftbedrockserver.env:EULA .env:(MINECRAFTBEDROCKSERVER_EULA|MINECRAFTBEDROCKSERVER_ENVIRONMENT_EULA)
minecraftbedrockserver.env:VERSION .env:(MINECRAFTBEDROCKSERVER_VERSION|MINECRAFTBEDROCKSERVER_ENVIRONMENT_VERSION)
