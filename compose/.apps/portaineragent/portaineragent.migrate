##
## PORTAINERAGENT - .env
##
.env:PORTAINERAGENT__CONTAINER_NAME .env:PORTAINERAGENT_CONTAINER_NAME
.env:PORTAINERAGENT__ENABLED .env:PORTAINERAGENT_ENABLED
.env:PORTAINERAGENT__NETWORK_MODE .env:PORTAINERAGENT_NETWORK_MODE
.env:PORTAINERAGENT__PORT_9001 .env:PORTAINERAGENT_PORT_9001
.env:PORTAINERAGENT__RESTART .env:PORTAINERAGENT_RESTART
.env:PORTAINERAGENT__TAG .env:PORTAINERAGENT_TAG
.env:PORTAINERAGENT__VOLUME_DOCKER_SOCKET .env:PORTAINERAGENT_VOLUME_DOCKER_SOCKET

##
## PORTAINERAGENT - portaineragent.env
##
portaineragent.env:CAP_HOST_MANAGEMENT .env:(PORTAINERAGENT_CAP_HOST_MANAGEMENT|PORTAINERAGENT_ENVIRONMENT_CAP_HOST_MANAGEMENT)
