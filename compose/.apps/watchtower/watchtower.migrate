##
## WATCHTOWER - .env
##
.env:WATCHTOWER__CONTAINER_NAME .env:WATCHTOWER_CONTAINER_NAME
.env:WATCHTOWER__ENABLED .env:WATCHTOWER_ENABLED
.env:WATCHTOWER__NETWORK_MODE .env:WATCHTOWER_NETWORK_MODE
.env:WATCHTOWER__RESTART .env:WATCHTOWER_RESTART
.env:WATCHTOWER__TAG .env:WATCHTOWER_TAG
.env:WATCHTOWER__VOLUME_DOCKER_SOCKET .env:WATCHTOWER_VOLUME_DOCKER_SOCKET

##
## WATCHTOWER - watchtower.env
##
watchtower.env:REPO_PASS .env:(WATCHTOWER_REPO_PASS|WATCHTOWER_ENVIRONMENT_REPO_PASS)
watchtower.env:REPO_USER .env:(WATCHTOWER_REPO_USER|WATCHTOWER_ENVIRONMENT_REPO_USER)
watchtower.env:WATCHTOWER_CLEANUP .env:(WATCHTOWER_WATCHTOWER_CLEANUP|WATCHTOWER_ENVIRONMENT_WATCHTOWER_CLEANUP)
watchtower.env:WATCHTOWER_INCLUDE_STOPPED .env:(WATCHTOWER_WATCHTOWER_INCLUDE_STOPPED|WATCHTOWER_ENVIRONMENT_WATCHTOWER_INCLUDE_STOPPED)
watchtower.env:WATCHTOWER_MONITOR_ONLY .env:(WATCHTOWER_WATCHTOWER_MONITOR_ONLY|WATCHTOWER_ENVIRONMENT_WATCHTOWER_MONITOR_ONLY)
watchtower.env:WATCHTOWER_NOTIFICATION_TEMPLATE .env:(WATCHTOWER_WATCHTOWER_NOTIFICATION_TEMPLATE|WATCHTOWER_ENVIRONMENT_WATCHTOWER_NOTIFICATION_TEMPLATE)
watchtower.env:WATCHTOWER_NOTIFICATION_URL .env:(WATCHTOWER_WATCHTOWER_NOTIFICATION_URL|WATCHTOWER_ENVIRONMENT_WATCHTOWER_NOTIFICATION_URL)
watchtower.env:WATCHTOWER_NOTIFICATIONS .env:(WATCHTOWER_WATCHTOWER_NOTIFICATIONS|WATCHTOWER_ENVIRONMENT_WATCHTOWER_NOTIFICATIONS)
watchtower.env:WATCHTOWER_NOTIFICATIONS_LEVEL .env:(WATCHTOWER_WATCHTOWER_NOTIFICATIONS_LEVEL|WATCHTOWER_ENVIRONMENT_WATCHTOWER_NOTIFICATIONS_LEVEL)
watchtower.env:WATCHTOWER_SCHEDULE .env:(WATCHTOWER_WATCHTOWER_SCHEDULE|WATCHTOWER_ENVIRONMENT_WATCHTOWER_SCHEDULE)
watchtower.env:WATCHTOWER_TIMEOUT .env:(WATCHTOWER_WATCHTOWER_TIMEOUT|WATCHTOWER_ENVIRONMENT_WATCHTOWER_TIMEOUT)
