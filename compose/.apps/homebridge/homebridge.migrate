##
## HOMEBRIDGE - .env
##
.env:HOMEBRIDGE__CONTAINER_NAME .env:HOMEBRIDGE_CONTAINER_NAME
.env:HOMEBRIDGE__ENABLED .env:HOMEBRIDGE_ENABLED
.env:HOMEBRIDGE__NETWORK_MODE .env:HOMEBRIDGE_NETWORK_MODE
.env:HOMEBRIDGE__PORT_8581 .env:HOMEBRIDGE_PORT_8581
.env:HOMEBRIDGE__RESTART .env:HOMEBRIDGE_RESTART
.env:HOMEBRIDGE__TAG .env:HOMEBRIDGE_TAG

##
## HOMEBRIDGE - homebridge.env
##
homebridge.env:ENABLE_AVAHI .env:(HOMEBRIDGE_ENABLE_AVAHI|HOMEBRIDGE_ENVIRONMENT_ENABLE_AVAHI)
