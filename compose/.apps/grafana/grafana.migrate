##
## GRAFANA - .env
##
.env:GRAFANA__CONTAINER_NAME .env:GRAFANA_CONTAINER_NAME
.env:GRAFANA__ENABLED .env:GRAFANA_ENABLED
.env:GRAFANA__NETWORK_MODE .env:GRAFANA_NETWORK_MODE
.env:GRAFANA__PORT_3000 .env:GRAFANA_PORT_3000
.env:GRAFANA__RESTART .env:GRAFANA_RESTART
.env:GRAFANA__TAG .env:GRAFANA_TAG

##
## GRAFANA - grafana.env
##
grafana.env:GF_INSTALL_PLUGINS .env:(GRAFANA_GF_INSTALL_PLUGINS|GRAFANA_ENVIRONMENT_GF_INSTALL_PLUGINS)
