##
## OMADACONTROLLER - omadacontroller.env
##
omadacontroller.env:SHOW_MONGODB_LOGS .env:(OMADACONTROLLER_SHOW_MONGODB_LOGS|OMADACONTROLLER_ENVIRONMENT_SHOW_MONGODB_LOGS)
omadacontroller.env:SHOW_SERVER_LOGS .env:(OMADACONTROLLER_SHOW_SERVER_LOGS|OMADACONTROLLER_ENVIRONMENT_SHOW_SERVER_LOGS)
omadacontroller.env:SMALL_FILES .env:(OMADACONTROLLER_SMALL_FILES|OMADACONTROLLER_ENVIRONMENT_SMALL_FILES)
