##
## TRANSMISSIONVPN - .env
##
.env:TRANSMISSIONVPN__CONTAINER_NAME .env:TRANSMISSIONVPN_CONTAINER_NAME
.env:TRANSMISSIONVPN__ENABLED .env:TRANSMISSIONVPN_ENABLED
.env:TRANSMISSIONVPN__NETWORK_MODE .env:TRANSMISSIONVPN_NETWORK_MODE
.env:TRANSMISSIONVPN__PORT_9091 .env:TRANSMISSIONVPN_PORT_9091
.env:TRANSMISSIONVPN__RESTART .env:TRANSMISSIONVPN_RESTART
.env:TRANSMISSIONVPN__TAG .env:TRANSMISSIONVPN_TAG

##
## TRANSMISSIONVPN - transmissionvpn.env
##
transmissionvpn.env:LOCAL_NETWORK .env:(TRANSMISSIONVPN_LOCAL_NETWORK|TRANSMISSIONVPN_ENVIRONMENT_LOCAL_NETWORK)
transmissionvpn.env:OPENVPN_PASSWORD .env:(TRANSMISSIONVPN_OPENVPN_PASSWORD|TRANSMISSIONVPN_ENVIRONMENT_OPENVPN_PASSWORD)
transmissionvpn.env:OPENVPN_PROVIDER .env:(TRANSMISSIONVPN_OPENVPN_PROVIDER|TRANSMISSIONVPN_ENVIRONMENT_OPENVPN_PROVIDER)
transmissionvpn.env:OPENVPN_USERNAME .env:(TRANSMISSIONVPN_OPENVPN_USERNAME|TRANSMISSIONVPN_ENVIRONMENT_OPENVPN_USERNAME)
transmissionvpn.env:TRANSMISSION_DOWNLOAD_DIR .env:(TRANSMISSIONVPN_DOWNLOAD_DIR|TRANSMISSIONVPN_ENVIRONMENT_DOWNLOAD_DIR)
transmissionvpn.env:TRANSMISSION_HOME .env:(TRANSMISSIONVPN_HOME|TRANSMISSIONVPN_ENVIRONMENT_HOME)
transmissionvpn.env:TRANSMISSION_INCOMPLETE_DIR .env:(TRANSMISSIONVPN_INCOMPLETE_DIR|TRANSMISSIONVPN_ENVIRONMENT_INCOMPLETE_DIR)
transmissionvpn.env:TRANSMISSION_WATCH_DIR .env:(TRANSMISSIONVPN_WATCH_DIR|TRANSMISSIONVPN_ENVIRONMENT_WATCH_DIR)
