##
## GUACAMOLE - .env
##
.env:GUACAMOLE__CONTAINER_NAME .env:GUACAMOLE_CONTAINER_NAME
.env:GUACAMOLE__ENABLED .env:GUACAMOLE_ENABLED
.env:GUACAMOLE__NETWORK_MODE .env:GUACAMOLE_NETWORK_MODE
.env:GUACAMOLE__PORT_8080 .env:GUACAMOLE_PORT_8080
.env:GUACAMOLE__RESTART .env:GUACAMOLE_RESTART
.env:GUACAMOLE__TAG .env:GUACAMOLE_TAG

##
## GUACAMOLE - guacamole.env
##
guacamole.env:EXTENSIONS .env:(GUACAMOLE_EXTENSIONS|GUACAMOLE_ENVIRONMENT_EXTENSIONS)
