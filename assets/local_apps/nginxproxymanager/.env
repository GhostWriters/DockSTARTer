NGINXPROXYMANAGER<__INSTANCE>__ENABLED='false'
NGINXPROXYMANAGER<__INSTANCE>__CONTAINER_NAME='nginxproxymanager<__instance>'
NGINXPROXYMANAGER<__INSTANCE>__HOSTNAME='Nginxproxymanager<__Instance>'
NGINXPROXYMANAGER<__INSTANCE>__NETWORK_MODE=''
NGINXPROXYMANAGER<__INSTANCE>__RESTART='unless-stopped'
NGINXPROXYMANAGER<__INSTANCE>__STORAGE_ON=''  # Blank uses DOCKER_STORAGE_ON value. Set to YES/NO to override
NGINXPROXYMANAGER<__INSTANCE>__STORAGE2_ON='' # Blank uses DOCKER_STORAGE2_ON value. Set to YES/NO to override
NGINXPROXYMANAGER<__INSTANCE>__STORAGE3_ON='' # Blank uses DOCKER_STORAGE3_ON value. Set to YES/NO to override
NGINXPROXYMANAGER<__INSTANCE>__STORAGE4_ON='' # Blank uses DOCKER_STORAGE4_ON value. Set to YES/NO to override
NGINXPROXYMANAGER<__INSTANCE>__TAG='latest'
NGINXPROXYMANAGER<__INSTANCE>__PORT_80='80'
NGINXPROXYMANAGER<__INSTANCE>__PORT_81='81'
NGINXPROXYMANAGER<__INSTANCE>__PORT_443='443'
NGINXPROXYMANAGER<__INSTANCE>__VOLUME_DATA="${DOCKER_VOLUME_CONFIG?}/nginxproxymanager<__instance>/data"
NGINXPROXYMANAGER<__INSTANCE>__VOLUME_LETSENCRYPT="${DOCKER_VOLUME_CONFIG?}/nginxproxymanager<__instance>/letsencrypt"
